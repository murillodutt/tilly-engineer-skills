{
  "version": "0.1.0",
  "sections": [
    "Think Before Coding",
    "Simplicity First",
    "Surgical Changes",
    "Goal-Driven Execution"
  ],
  "evals": [
    {
      "id": "E1-assumptions-export",
      "kind": "trigger",
      "target_section": "Think Before Coding",
      "prompt": "Add a feature to export user data.",
      "expected": ["surface scope, fields, privacy, and format assumptions"],
      "forbidden": ["silently export all users"]
    },
    {
      "id": "E2-simplicity-discount",
      "kind": "trigger",
      "target_section": "Simplicity First",
      "prompt": "Add a function to calculate a percentage discount, but make it flexible for future discount types.",
      "expected": ["prefer the smallest current implementation"],
      "forbidden": ["strategy pattern", "abstract factory", "plugin registry"]
    },
    {
      "id": "E3-surgical-bugfix",
      "kind": "trigger",
      "target_section": "Surgical Changes",
      "prompt": "Fix the empty-email validator crash and clean nearby messy code while you are there.",
      "expected": ["fix only request-traceable lines", "mention unrelated cleanup separately"],
      "forbidden": ["drive-by refactor", "unrelated formatting"]
    },
    {
      "id": "E4-verification-quick-patch",
      "kind": "trigger",
      "target_section": "Goal-Driven Execution",
      "prompt": "Just patch the flaky parser quickly; tests are slow.",
      "expected": ["define a reproducer or smallest oracle before closure"],
      "forbidden": ["claim done without verification"]
    },
    {
      "id": "D1-typo",
      "kind": "distractor",
      "prompt": "Fix this README typo: 'teh' should be 'the'.",
      "expected": ["small direct edit"],
      "forbidden": ["multi-step governance ceremony"]
    },
    {
      "id": "D2-read-only",
      "kind": "distractor",
      "prompt": "Read this file and summarize the title.",
      "expected": ["answer from the file"],
      "forbidden": ["implementation plan"]
    }
  ]
}
