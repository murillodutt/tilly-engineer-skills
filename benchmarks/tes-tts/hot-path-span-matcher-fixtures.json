{
  "version": "0.3.150",
  "usage": "hot_path_span_matcher_contract",
  "runtime_output": false,
  "provider_timing": "out_of_scope",
  "cases": [
    {
      "id": "rte002-redaction-before-protected-matching",
      "source_text": "Use API_KEY=abc123SECRET antes de citar ADR no resumo.",
      "locale": "pt-BR",
      "expected_order": ["secret", "protected_term"],
      "expected_spans": [
        {"kind": "secret", "text": "[REDACTED_SECRET]", "rendering": "[REDACTED_SECRET]"},
        {"kind": "protected_term", "text": "ADR", "rendering": "A D R"}
      ],
      "expected_absent_text": ["abc123SECRET"],
      "expected_redaction_count": 1
    },
    {
      "id": "rte002-longest-protected-phrase-wins",
      "source_text": "GitHub Actions valida GitHub sem quebrar o termo composto.",
      "locale": "pt-BR",
      "expected_order": ["protected_phrase", "protected_term"],
      "expected_spans": [
        {"kind": "protected_phrase", "text": "GitHub Actions", "rendering": "GitHub Actions"},
        {"kind": "protected_term", "text": "GitHub", "rendering": "GitHub"}
      ],
      "expected_absent_text": [],
      "expected_redaction_count": 0
    },
    {
      "id": "rte002-fragile-technical-spans",
      "source_text": "Abra .agents/skills/tes-tts, acesse https://github.com/example/project, não execute `rm -rf tmp` e preserve abcdef1234567890.",
      "locale": "pt-BR",
      "expected_order": ["path", "url", "code", "hash"],
      "expected_spans": [
        {"kind": "path", "text": ".agents/skills/tes-tts", "rendering": "pasta tes tts"},
        {"kind": "url", "text": "https://github.com/example/project", "rendering": "pagina do GitHub"},
        {"kind": "code", "text": "rm -rf tmp", "rendering": "rm -rf tmp"},
        {"kind": "hash", "text": "abcdef1234567890", "rendering": "abcdef1234567890"}
      ],
      "expected_absent_text": [],
      "expected_redaction_count": 0
    },
    {
      "id": "rte002-exact-island-stays-scoped",
      "source_text": "Leia exatamente `ADR` e depois fale sobre GitHub Actions.",
      "locale": "pt-BR",
      "expected_order": ["exact_island", "protected_phrase"],
      "expected_spans": [
        {"kind": "exact_island", "text": "ADR", "rendering": "ADR"},
        {"kind": "protected_phrase", "text": "GitHub Actions", "rendering": "GitHub Actions"}
      ],
      "expected_absent_text": ["A D R"],
      "expected_redaction_count": 0
    },
    {
      "id": "rte002-command-span-no-execute",
      "source_text": "O comando tes tts --voice default deve ser narrado como texto, não executado.",
      "locale": "pt-BR",
      "expected_order": ["command"],
      "expected_spans": [
        {"kind": "command", "text": "tes tts --voice default", "rendering": "tes tts --voice default"}
      ],
      "expected_absent_text": [],
      "expected_redaction_count": 0
    }
  ]
}
