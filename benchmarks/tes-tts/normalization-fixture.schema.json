{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tilly.engineer/schemas/tes-tts-normalization-fixture.schema.json",
  "title": "TES TTS normalization fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "class",
    "selector",
    "source_text",
    "expected_target_language",
    "protected_terms",
    "redaction",
    "provider_state",
    "expected_status",
    "no_summary"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^tts-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "class": {
      "type": "string",
      "enum": [
        "default_language_selector",
        "language_normalization",
        "protected_terms",
        "redaction",
        "markdown_transform",
        "provider_fallback",
        "pronunciation_hint"
      ]
    },
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "explicit_user_language",
        "declared_adapter_default",
        "request_language",
        "dominant_text_language"
      ],
      "properties": {
        "explicit_user_language": {
          "$ref": "#/$defs/language_or_absent"
        },
        "declared_adapter_default": {
          "$ref": "#/$defs/language_or_unknown"
        },
        "request_language": {
          "$ref": "#/$defs/language_or_unclear"
        },
        "dominant_text_language": {
          "$ref": "#/$defs/language_or_unclear"
        }
      }
    },
    "source_text": {
      "type": "string",
      "minLength": 1
    },
    "expected_target_language": {
      "$ref": "#/$defs/target_language"
    },
    "protected_terms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "term",
          "kind",
          "must_preserve"
        ],
        "properties": {
          "term": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "acronym",
              "technical_term",
              "proper_noun",
              "command",
              "path",
              "code_identifier",
              "model_name",
              "package_name"
            ]
          },
          "must_preserve": {
            "type": "boolean",
            "const": true
          },
          "pronunciation_hint_expected": {
            "type": "boolean"
          }
        }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contains_secret_like_value",
        "expected_redactions"
      ],
      "properties": {
        "contains_secret_like_value": {
          "type": "boolean"
        },
        "expected_redactions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "provider_state": {
      "$ref": "#/$defs/provider_state"
    },
    "expected_status": {
      "$ref": "#/$defs/expected_status"
    },
    "no_summary": {
      "type": "boolean",
      "const": true
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "language": {
      "type": "string",
      "enum": [
        "pt-BR",
        "en",
        "es",
        "fr",
        "it",
        "de",
        "he"
      ]
    },
    "language_or_absent": {
      "type": "string",
      "enum": [
        "absent",
        "pt-BR",
        "en",
        "es",
        "fr",
        "it",
        "de",
        "he"
      ]
    },
    "language_or_unknown": {
      "type": "string",
      "enum": [
        "unknown",
        "pt-BR",
        "en",
        "es",
        "fr",
        "it",
        "de",
        "he"
      ]
    },
    "language_or_unclear": {
      "type": "string",
      "enum": [
        "unclear",
        "pt-BR",
        "en",
        "es",
        "fr",
        "it",
        "de",
        "he"
      ]
    },
    "target_language": {
      "type": "string",
      "enum": [
        "preserve_original",
        "pt-BR",
        "en",
        "es",
        "fr",
        "it",
        "de",
        "he"
      ]
    },
    "provider_state": {
      "type": "string",
      "enum": [
        "provider_available",
        "provider_not_available",
        "provider_needs_review",
        "normalization_degraded",
        "tts_not_available"
      ]
    },
    "expected_status": {
      "type": "string",
      "enum": [
        "PASS",
        "DEGRADED",
        "NEEDS_REVIEW",
        "BLOCKED"
      ]
    }
  }
}
