{
  "version": "0.3.158",
  "description": "Adversarial secret-redaction fixtures for the P-1 hardening line (GOAL-SUPER-SPEC-tes-tts-secret-redaction-hardening). Each case feeds redact_secret_like_values and asserts the secret value never survives in redacted_text. Free-prose secrets are intentionally out of target.",
  "cases": [
    {
      "id": "compound-access-token",
      "source_text": "deploy with access_token=ghp_AbC1234567890Def and continue",
      "leaked_value": "ghp_AbC1234567890Def",
      "must_redact": true
    },
    {
      "id": "compound-refresh-token",
      "source_text": "rotate refresh_token=rt_9xY8zAbCdEf12345 now",
      "leaked_value": "rt_9xY8zAbCdEf12345",
      "must_redact": true
    },
    {
      "id": "compound-client-secret",
      "source_text": "the client_secret=swordfishLongSecretValue must stay hidden",
      "leaked_value": "swordfishLongSecretValue",
      "must_redact": true
    },
    {
      "id": "compound-db-password",
      "source_text": "set db_password=Pa55wordValue in the env",
      "leaked_value": "Pa55wordValue",
      "must_redact": true
    },
    {
      "id": "compound-aws-secret-access-key",
      "source_text": "aws_secret_access_key=AbC123xYz456SecretKey is sensitive",
      "leaked_value": "AbC123xYz456SecretKey",
      "must_redact": true
    },
    {
      "id": "bare-uppercase-password",
      "source_text": "PASSWORD=topSecretValue should never be spoken",
      "leaked_value": "topSecretValue",
      "must_redact": true
    },
    {
      "id": "bare-uppercase-token",
      "source_text": "TOKEN=liveTokenValue123 in plaintext",
      "leaked_value": "liveTokenValue123",
      "must_redact": true
    },
    {
      "id": "bare-uppercase-secret",
      "source_text": "SECRET=mySecretValue99 leaks",
      "leaked_value": "mySecretValue99",
      "must_redact": true
    },
    {
      "id": "mixed-case-token",
      "source_text": "Token=HunterTwoValue here",
      "leaked_value": "HunterTwoValue",
      "must_redact": true
    },
    {
      "id": "mixed-case-api-key",
      "source_text": "Api_Key=mixedCaseKeyValue set",
      "leaked_value": "mixedCaseKeyValue",
      "must_redact": true
    },
    {
      "id": "special-char-value-no-suffix-leak",
      "source_text": "password=p@ssw0rd!Value done",
      "leaked_value": "ssw0rd",
      "must_redact": true
    },
    {
      "id": "standalone-prefix-sk-proj",
      "source_text": "use sk-proj-ABC1234567890XYZdef for access",
      "leaked_value": "sk-proj-ABC1234567890XYZdef",
      "must_redact": true
    },
    {
      "id": "standalone-prefix-ghp",
      "source_text": "token ghp_abcdef1234567890ABCDEF set",
      "leaked_value": "ghp_abcdef1234567890ABCDEF",
      "must_redact": true
    },
    {
      "id": "standalone-prefix-aws-akia",
      "source_text": "id AKIAIOSFODNN7EXAMPLE in config",
      "leaked_value": "AKIAIOSFODNN7EXAMPLE",
      "must_redact": true
    },
    {
      "id": "compound-private-key",
      "source_text": "set private_key=abc123SECRET for the deploy step",
      "leaked_value": "abc123SECRET",
      "must_redact": true
    },
    {
      "id": "compound-ssh-private-key",
      "source_text": "set ssh_private_key=sshSecretValue123 before continuing",
      "leaked_value": "sshSecretValue123",
      "must_redact": true
    },
    {
      "id": "bare-uppercase-private-key",
      "source_text": "PRIVATE_KEY=upperSecretValue123 must not be spoken",
      "leaked_value": "upperSecretValue123",
      "must_redact": true
    },
    {
      "id": "pem-private-key-block",
      "source_text": "load -----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASC\n-----END PRIVATE KEY----- then continue",
      "leaked_value": "MIIEvQIBADANBgkqhkiG9w0BAQEFAASC",
      "must_redact": true
    },
    {
      "id": "invariant-api-key-lowercase",
      "source_text": "api_key=lowercaseKeyValue stays redacted",
      "leaked_value": "lowercaseKeyValue",
      "must_redact": true,
      "invariant": "already redacted at baseline; must not regress"
    },
    {
      "id": "invariant-token-lowercase",
      "source_text": "token=lowercaseTokenValue stays redacted",
      "leaked_value": "lowercaseTokenValue",
      "must_redact": true,
      "invariant": "already redacted at baseline; must not regress"
    },
    {
      "id": "invariant-prefixed-uppercase-password",
      "source_text": "MY_PASSWORD=prefixedValue stays redacted",
      "leaked_value": "prefixedValue",
      "must_redact": true,
      "invariant": "already redacted at baseline; must not regress"
    },
    {
      "id": "invariant-bearer-token",
      "source_text": "Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6 here",
      "leaked_value": "eyJhbGciOiJIUzI1NiIsInR5cCI6",
      "must_redact": true,
      "invariant": "already redacted at baseline; must not regress"
    },
    {
      "id": "negative-plain-prose-not-required",
      "source_text": "the build finished and the cat ran fast across the room",
      "leaked_value": null,
      "must_redact": false,
      "note": "no secret present; redaction must not fire"
    }
  ]
}
