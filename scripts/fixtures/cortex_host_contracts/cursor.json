{
  "fixture_schema": "tes.cortex.host-contract.v1",
  "host": "cursor",
  "source_refs": [
    "https://cursor.com/docs/hooks.md",
    "https://cursor.com/docs/reference/third-party-hooks.md"
  ],
  "contract": {
    "config_surfaces": [
      ".cursor/hooks.json"
    ],
    "event_case": "camelCase",
    "lifecycle_events": {
      "advisory_recall": "sessionStart",
      "capture_proposal": "stop",
      "needs_align": "preToolUse"
    },
    "output_style": "cursor-json-permission-continue",
    "blocks_with_exit_code_2": false
  },
  "samples": [
    {
      "name": "session_start_advisory_recall",
      "intent": "advisory_recall",
      "event": "sessionStart",
      "input": {
        "session_id": "session-cursor-001",
        "transcript_path": "/tmp/target-project/.cursor/transcript.jsonl",
        "cwd": "/tmp/target-project",
        "hook_event_name": "sessionStart",
        "cursor_version": "1.7.2",
        "workspace_roots": [
          "/tmp/target-project"
        ]
      },
      "output": {
        "exit_code": 0,
        "stdout": {
          "continue": true,
          "agent_message": "Cortex recall is advisory: review retained project context before editing."
        },
        "stderr": ""
      }
    },
    {
      "name": "stop_capture_proposal",
      "intent": "capture_proposal",
      "event": "stop",
      "input": {
        "session_id": "session-cursor-001",
        "transcript_path": "/tmp/target-project/.cursor/transcript.jsonl",
        "cwd": "/tmp/target-project",
        "hook_event_name": "stop",
        "conversation_id": "conversation-cursor-001",
        "generation_id": "generation-cursor-001",
        "status": "completed",
        "loop_count": 0
      },
      "output": {
        "exit_code": 0,
        "stdout": {
          "continue": true,
          "followup_message": "Capture proposal requires explicit authorization before any durable Cortex write."
        },
        "stderr": ""
      }
    },
    {
      "name": "pre_tool_use_needs_align",
      "intent": "needs_align",
      "event": "preToolUse",
      "input": {
        "session_id": "session-cursor-001",
        "transcript_path": "/tmp/target-project/.cursor/transcript.jsonl",
        "cwd": "/tmp/target-project",
        "hook_event_name": "preToolUse",
        "tool_name": "Write",
        "tool_input": {
          "file_path": "/tmp/target-project/docs/agents/PROJECT-STATE.md",
          "content": "next"
        }
      },
      "output": {
        "exit_code": 0,
        "stdout": {
          "continue": true,
          "permission": "allow",
          "user_message": "Project mesh may be stale.",
          "agent_message": "status=NEEDS_ALIGN evidence_refs=docs/agents/PROJECT-STATE.md next_action=run /tes-align before claiming alignment."
        },
        "stderr": ""
      }
    }
  ],
  "negative_cases": [
    {
      "name": "reject_claude_nested_output",
      "event": "preToolUse",
      "output": {
        "exit_code": 0,
        "stdout": {
          "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "additionalContext": "Wrong native output."
          }
        },
        "stderr": ""
      }
    },
    {
      "name": "reject_exit_code_blocking_as_native_contract",
      "event": "preToolUse",
      "output": {
        "exit_code": 2,
        "stdout": {},
        "stderr": "Wrong native output."
      }
    }
  ]
}
