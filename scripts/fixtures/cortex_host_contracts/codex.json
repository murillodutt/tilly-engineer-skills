        "model": "codex-model",
        "source": "startup"
      },
      "output": {
        "exit_code": 0,
        "stdout": {
          "hookSpecificOutput": {
            "hookEventName": "SessionStart",
            "additionalContext": "Cortex recall is advisory: review retained project context before editing."
          }
        },
        "stderr": ""
      }
    },
    {
      "name": "stop_capture_proposal",
      "intent": "capture_proposal",
      "event": "Stop",
      "input": {
        "session_id": "session-codex-001",
        "transcript_path": "/tmp/target-project/.codex/transcript.jsonl",
        "cwd": "/tmp/target-project",
        "hook_event_name": "Stop",
        "model": "codex-model",
        "permission_mode": "default",
        "turn_id": "turn-codex-001",
        "stop_hook_active": false,
        "last_assistant_message": "Implemented a focused local fixture."
      },
            "output": {
                "exit_code": 0,
                "stdout": {
                    "hookSpecificOutput": {
                        "hookEventName": "Stop",
                        "additionalContext": "Capture proposal: retain this as candidate evidence only after explicit authorization."
                    }
                },
                "stderr": ""
            }
        },
    {
      "name": "pre_tool_use_needs_align",
      "intent": "needs_align",
      "event": "PreToolUse",
      "input": {
        "session_id": "session-codex-001",
        "transcript_path": "/tmp/target-project/.codex/transcript.jsonl",
        "cwd": "/tmp/target-project",
        "hook_event_name": "PreToolUse",
        "model": "codex-model",
        "permission_mode": "default",
        "turn_id": "turn-codex-001",
        "tool_name": "apply_patch",
