{
  "name": "tilly-engineer-skills",
  "version": "0.1.0",
  "private": true,
  "description": "Portable engineering discipline and context-mesh method for coding agents.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "validate": "python3 scripts/validate_reference_package.py",
    "materialize:all": "python3 scripts/materialize_adapter.py all",
    "materialize:codex": "python3 scripts/materialize_adapter.py codex",
    "materialize:cursor": "python3 scripts/materialize_adapter.py cursor",
    "materialize:claude": "python3 scripts/materialize_adapter.py claude",
    "materialize:check": "python3 scripts/materialize_adapter.py all --check",
    "tds:validate": "python3 scripts/validate_tds.py",
    "oracle:self-test": "python3 src/adapters/codex/skills/tilly-engineering-discipline/scripts/discipline_oracle.py --self-test",
    "benchmark:plan": "python3 scripts/context_mesh_plan.py",
    "benchmark:run": "python3 scripts/context_mesh_run.py",
    "git:diff-check": "git diff --check && git diff --cached --check",
    "commit:check": "python3 scripts/validate_reference_package.py --staged-ready && python3 scripts/validate_tds.py && python3 scripts/context_mesh_plan.py && python3 scripts/materialize_adapter.py all --check && git diff --check && git diff --cached --check"
  }
